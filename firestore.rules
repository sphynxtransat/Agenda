rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Single-user agenda app: only expose the one document used by the app.
    // Requires a valid Firebase ID token (anonymous auth obtained by the app on load).
    match /agendas/user-arcange {
      allow read, write: if request.auth != null;
    }

    // Deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
